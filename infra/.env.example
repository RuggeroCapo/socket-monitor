# Copy to .env and fill in. Compose reads .env from this directory.

# Postgres
DB_USER=postgres
DB_PASSWORD=changeme
DB_NAME=vinestats

# Used by writer + web. Must match the db service credentials above.
DATABASE_URL=postgres://postgres:changeme@db:5432/vinestats

# Optional: override the Vine IT socket URL
SOCKET_URL=

# Public domain Caddy will serve and provision a TLS cert for.
# Leave empty in dev to fall back to the placeholder.
WEB_DOMAIN=vine-stats.example.it

# Image tags. In production set these to the commit hash you pushed
# to your registry, e.g. ghcr.io/you/vine-stats-writer:abc1234
WRITER_IMAGE=vine-stats-writer:dev
NOTIFIER_IMAGE=vine-stats-notifier:dev
WEB_IMAGE=vine-stats-web:dev

# Optional: enable the Telegram notifier service profile.
# COMPOSE_PROFILES=notifier

LOG_LEVEL=INFO

# Telegram notifier (required only when the notifier profile is enabled)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_DISABLE_PREVIEW=true
TELEGRAM_BATCH_SIZE=10
TELEGRAM_IDLE_POLL_SECONDS=30
TELEGRAM_LEASE_SECONDS=120
TELEGRAM_RETRY_BASE_SECONDS=15
TELEGRAM_RETRY_MAX_SECONDS=900
TELEGRAM_SENT_RETENTION_DAYS=14
TELEGRAM_CLEANUP_INTERVAL_HOURS=24
TELEGRAM_VINE_URL_TEMPLATE=https://www.amazon.it/dp/{asin}
